# Dual-tenant claim → confirm E2E
# Copy to .env.e2e.local (never commit secrets)

PLAYWRIGHT_BASE_URL=https://www.supplieradvisor.com
E2E_MUTATE=1
E2E_CONFIRM_CLAIM=1

# Seller (confirms claims)
E2E_ACCESS_TOKEN=
E2E_COMPANY_ID=

# Buyer (creates claims)
E2E_BUYER_TOKEN=
E2E_BUYER_COMPANY_ID=

# Optional shared open invoice
E2E_INVOICE_ID=

# Optional credit-hold probe customer id
E2E_CREDIT_HOLD_CUSTOMER_ID=

# Run:
#   set -a && source .env.e2e.local && set +a
#   npx playwright test e2e/claim-settle-dual.spec.ts e2e/paystack-cipc-drill.spec.ts
