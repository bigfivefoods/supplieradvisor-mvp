# ==================== App ====================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================== Privy Auth ====================
NEXT_PUBLIC_PRIVY_APP_ID=
# Tier-1: JWT verification against Privy JWKS (required in production)
# AUTH_STRICT defaults true on Vercel production / NODE_ENV=production
AUTH_STRICT=true
# Never enable in production — allows body privyUserId without Bearer token
# AUTH_ALLOW_LEGACY_PRIVY_ID=false

# ==================== Twilio WhatsApp (optional alerts) ====================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO_DEFAULT=whatsapp:+27XXXXXXXXX

# ==================== E2E (Playwright) ====================
# E2E_ACCESS_TOKEN=   # Privy access JWT from browser session
# E2E_COMPANY_ID=1
# PLAYWRIGHT_BASE_URL=https://www.supplieradvisor.com

# ==================== Supabase ====================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — required for invite APIs
SUPABASE_SERVICE_ROLE_KEY=

# ==================== Wallet / On-chain ====================
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BASE_SEPOLIA_RPC=
NEXT_PUBLIC_SEPOLIA_RPC=
NEXT_PUBLIC_SUPPLIER_REGISTRY_ADDRESS=
SEPOLIA_RPC_URL=
PRIVATE_KEY=
# POEscrowV2 (Hardhat) — Ethereum Sepolia default (matches contracts/contracts/deployments)
NEXT_PUBLIC_PO_ESCROW_ADDRESS=0x1a0a30b07ad50b5373a088d5c81dbbf3e644a06f
NEXT_PUBLIC_PO_ESCROW_CHAIN_ID=11155111
# Demo fiat→ETH rate for fundPO (ZAR per 1 ETH). Replace with oracle in production.
NEXT_PUBLIC_ETH_DEMO_RATE=55000
# Server receipt verification (default true). Set false only for offline dev.
ESCROW_VERIFY_STRICT=true
# InventoryPassport (contracts/src/InventoryPassport.sol)
# Chains: 11155111 Ethereum Sepolia | 84532 Base Sepolia | 8453 Base
# Deployed Sepolia (2026-07-16): 0xe63dE681DafEB192bac731b1f13809a0E0E3EC5D
NEXT_PUBLIC_INVENTORY_PASSPORT_ADDRESS=0xe63dE681DafEB192bac731b1f13809a0E0E3EC5D
INVENTORY_PASSPORT_ADDRESS=0xe63dE681DafEB192bac731b1f13809a0E0E3EC5D
NEXT_PUBLIC_INVENTORY_CHAIN_ID=11155111
# Minter wallet private key (must be minter/owner on the contract; pays gas)
# PRIVATE_KEY=0x...
# Optional RPC (defaults to public Sepolia)
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Production refuses simulated passport mint unless:
# ALLOW_SIMULATED_PASSPORT=1

# USDC stablecoin escrow on Base (POEscrowUSDC.sol)
# Deploy: contracts/contracts/contracts/POEscrowUSDC.sol with USDC token address
NEXT_PUBLIC_USDC_ESCROW_ENABLED=false
NEXT_PUBLIC_USDC_ESCROW_ADDRESS=
NEXT_PUBLIC_USDC_ESCROW_CHAIN_ID=84532
# Circle USDC Base Sepolia default if unset: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=
# Demo ZAR per 1 USD for fiat→USDC conversion
NEXT_PUBLIC_ZAR_PER_USD=18


# ==================== Payments ====================
# Paystack (company SaaS R499/mo + CIPC verify + sales contractor)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Server-side verify for company subscription activate (required in production)
PAYSTACK_SECRET_KEY=
# Optional extra company IDs with lifetime free access (comma-separated)
# LIFETIME_COMPANY_IDS=102,110,120,123,124,125
STRIPE_SECRET_KEY=

# ==================== Email ====================
RESEND_API_KEY=
# Verified Resend sender — domain must be verified at resend.com/domains
# Production verified domain is supplieradvisor.com (not .co.za)
# Any local-part works once the domain is verified (invites@, team@, noreply@).
RESEND_FROM_EMAIL=SupplierAdvisor <invites@supplieradvisor.com>
# Where recipient replies go (use a real inbox you monitor)
RESEND_REPLY_TO=connect@supplieradvisor.com
# Ops inbox for new company registration alerts (comma-separated ok)
# NEW_COMPANY_NOTIFY_EMAIL=connect@supplieradvisor.com
# PLATFORM_OPS_EMAIL=connect@supplieradvisor.com


# ==================== SAM — Supplier Advisor Messenger (Grok / xAI) ====================
# Server-only key from https://console.x.ai — never expose to the browser
XAI_API_KEY=
# Optional overrides
# XAI_BASE_URL=https://api.x.ai/v1
# SAM_MODEL=grok-4.5
# XAI_MODEL=grok-4.5

# ==================== Supply-chain referral (watertight) ====================
# Programme root company id (ops ownership + optional default parent)
# REFERRAL_ROOT_PROFILE_ID=102
# When true, unattributed companies default under root. Default false = explicit invite/ref only.
# REFERRAL_DEFAULT_ROOT=false
# Hold days after payment before auto-approve / requestable
# REFERRAL_HOLD_DAYS=30
# KYC bank details required above this payout amount (ZAR)
# REFERRAL_KYC_THRESHOLD_ZAR=500
# Annual paid+requested cap without full KYC (ZAR)
# REFERRAL_ANNUAL_CAP_WITHOUT_KYC_ZAR=5000
# Platform ops secret for approve / mark_paid / void / clawback (falls back to CRON_SECRET)
# REFERRAL_OPS_SECRET=
# Extra company profile ids whose owners may act as referral ops (comma-separated)
# REFERRAL_OPS_PROFILE_IDS=

# ==================== Feature flags (env-only v1) ====================
# Customer platform invites (POST/GET /api/customers/invites). Default true if unset.
CUSTOMER_INVITES_ENABLED=true
# Post-PO peer reviews APIs. Default true if unset.
PO_REVIEWS_ENABLED=true
# Optional client-signed POEscrowV2. Default false (world-class: never show broken escrow).
# MUST set BOTH server + NEXT_PUBLIC_ twins or UI and API will disagree:
# Customer portal POs (/dashboard/buyer/pos):
CUSTOMER_PO_ESCROW_ENABLED=false
NEXT_PUBLIC_CUSTOMER_PO_ESCROW_ENABLED=false
# SRM buyer POs (/dashboard/suppliers/po):
SUPPLIER_PO_ESCROW_ENABLED=false
NEXT_PUBLIC_SUPPLIER_PO_ESCROW_ENABLED=false

# ==================== Maintenance / cron ====================
# Bearer secret for POST /api/customers/invites/expire (reap stuck claiming + expire pending).
# Also accepted as CUSTOMER_INVITE_EXPIRE_SECRET. Send: Authorization: Bearer <secret>
# or header x-cron-secret. Company members can call expire with companyId + privyUserId instead.
# Also used by /api/business/referrals/cron (auto-approve holds) and banking cron-sync.
CRON_SECRET=

# Paystack webhook: https://www.supplieradvisor.com/api/paystack/webhook
# (uses PAYSTACK_SECRET_KEY for signature verification; refunds claw back referral fees)



# ==================== Verification (https://www.verifynow.co.za) ====================
# Server-only API key from VerifyNow Settings (starts with vn_live_).
# Used by /api/business/verify (CIPC company) and /api/containers/contractors/verify (SA ID).
# Never expose this key in NEXT_PUBLIC_* vars or client code.
VERIFYNOW_API_KEY=
# production | sandbox (sandbox uses 0 credits)
VERIFYNOW_MODE=production

# ==================== Optional: remote schema apply ====================
# Not required at runtime. Used by scripts/apply-schema.mjs alternatives.
# DATABASE_URL=
# SUPABASE_DB_URL=
# SUPABASE_ACCESS_TOKEN=
