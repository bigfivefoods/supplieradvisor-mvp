# ==================== App ====================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================== Privy Auth ====================
NEXT_PUBLIC_PRIVY_APP_ID=

# ==================== Supabase ====================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — required for invite APIs
SUPABASE_SERVICE_ROLE_KEY=

# ==================== Wallet / On-chain ====================
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BASE_SEPOLIA_RPC=
NEXT_PUBLIC_SUPPLIER_REGISTRY_ADDRESS=
SEPOLIA_RPC_URL=
PRIVATE_KEY=
# InventoryPassport (contracts/src/InventoryPassport.sol) — Base Sepolia or Base
NEXT_PUBLIC_INVENTORY_PASSPORT_ADDRESS=
INVENTORY_PASSPORT_ADDRESS=
NEXT_PUBLIC_INVENTORY_CHAIN_ID=84532


# ==================== Payments ====================
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ==================== Email ====================
RESEND_API_KEY=

# ==================== Feature flags (env-only v1) ====================
# Customer platform invites (POST/GET /api/customers/invites). Default true if unset.
CUSTOMER_INVITES_ENABLED=true
# Optional client-signed POEscrowV2 for buyer-raised customer POs. Default false.
# Set NEXT_PUBLIC_ too so the buyer PO UI can show the escrow path (build-time).
CUSTOMER_PO_ESCROW_ENABLED=false
NEXT_PUBLIC_CUSTOMER_PO_ESCROW_ENABLED=false

# ==================== Verification (https://www.verifynow.co.za) ====================
# API key from VerifyNow Settings (starts with vn_live_)
VERIFYNOW_API_KEY=
# production | sandbox (sandbox uses 0 credits)
VERIFYNOW_MODE=production

# ==================== Optional: remote schema apply ====================
# Not required at runtime. Used by scripts/apply-schema.mjs alternatives.
# DATABASE_URL=
# SUPABASE_DB_URL=
# SUPABASE_ACCESS_TOKEN=
